# Freeflow Server Configuration
# Copy to .env to customize (gitignored)
# This template serves as documentation

# WebSocket Server Port
WS_PORT=3000

# Vite Dev Server Port
VITE_PORT=3001


# STAGE_DIR: Where Vite serves from (HMR active) - relative to workspace
STAGE_DIR=stage
# SHADOW_DIR: Where AI edits (no HMR) - relative to workspace
SHADOW_DIR=shadow

# Vite binary - 'bunx' or path to npx
VITE_BIN=bunx

# AI Brain CLI Command
# Examples: claude, claude-opus, claude --verbose, /path/to/custom-claude
AGENT_CLI_CMD=claude

# Optional wrapper script that takes precedence over AGENT_CLI_CMD
# AGENT_CLI_WRAPPER=claude --verbose

# Log configuration
LOG_DIR=./logs
LOG_LEVEL=INFO  # DEBUG, INFO, WARN, ERROR
